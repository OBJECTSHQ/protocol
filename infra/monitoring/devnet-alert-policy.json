{
  "displayName": "Devnet Uptime Failures",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Registry uptime check failing",
      "conditionThreshold": {
        "filter": "metric.type=\"monitoring.googleapis.com/uptime_check/check_passed\" AND metric.label.check_id=\"registry-health-OziyeK6kXKs\" AND resource.type=\"uptime_url\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_NEXT_OLDER",
            "crossSeriesReducer": "REDUCE_COUNT_FALSE",
            "groupByFields": ["resource.label.*"]
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 1,
        "duration": "600s",
        "trigger": { "count": 1 }
      }
    },
    {
      "displayName": "Bootstrap US uptime check failing",
      "conditionThreshold": {
        "filter": "metric.type=\"monitoring.googleapis.com/uptime_check/check_passed\" AND metric.label.check_id=\"bootstrap-us-health-OziyeK6kVQY\" AND resource.type=\"uptime_url\"",
